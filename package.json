{
  "name": "website-automation-agent",
  "version": "1.0.0",
  "description": "Mini website automation agent for filling forms with Playwright.",
  "main": "dist/index.js",
  "bin": {
    "web-agent": "dist/cli.js"
  },
  "scripts": {
    "agent": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "demo": "tsx src/cli.ts demo",
    "inspect": "tsx src/cli.ts inspect",
    "tools": "tsx src/cli.ts tools",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "install:browsers": "npx playwright install chromium"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "dotenv": "^17.4.2",
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
